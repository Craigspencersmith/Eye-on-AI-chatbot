# OpenAI API key (required for embeddings + chat)
OPENAI_API_KEY=sk-your-key-here

# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# Model to use for chat completions
LLM_MODEL=gpt-4o

# Anthropic API key (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Drive folder ID containing transcripts
DRIVE_FOLDER_ID=178HN2Eldzshqt4pQwalArOfz9xL1XWbB

# Path to Google service account JSON
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Chunk size and overlap for splitting transcripts
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Sync interval in seconds (default: 1 hour)
SYNC_INTERVAL=3600

# Number of chunks to retrieve per query
TOP_K=10
