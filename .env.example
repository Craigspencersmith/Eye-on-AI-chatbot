# Eye on AI Podcast Chatbot - Environment Configuration
# Copy this file to .env and fill in your values

# === LLM Configuration ===
# Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
# Model name (e.g., gpt-4o, claude-sonnet-4-20250514)
LLM_MODEL=gpt-4o

# === API Keys ===
OPENAI_API_KEY=sk-your-openai-api-key-here
# Required only if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# === Google Drive ===
GOOGLE_CREDENTIALS_PATH=credentials.json
DRIVE_FOLDER_ID=178HN2Eldzshqt4pQwalArOfz9xL1XWbB

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_data

# === Chunking ===
# Approximate tokens per chunk
CHUNK_SIZE=1000
# Overlap between chunks in tokens
CHUNK_OVERLAP=200

# === Retrieval ===
# Number of chunks to retrieve per query
TOP_K=8

# === Server ===
HOST=0.0.0.0
PORT=8000
# Comma-separated origins for CORS (use * for development)
CORS_ORIGINS=*
